# ── Cattle Health Monitor — Frontend Configuration ──
# Copy this file as .env and adjust values for your deployment.

# Backend API base URL (no trailing slash)
BASE_URL=http://127.0.0.1:8000

# Default UI language: en | ta | hi
DEFAULT_LANG=en

# Streamlit server settings (used by Dockerfile / CLI override)
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
